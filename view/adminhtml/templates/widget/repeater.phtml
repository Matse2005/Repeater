<?php
/** @var MatseVH\Repeater\Block\Adminhtml\Widget\Repeater $block */
$element     = $block->getElement();
$elementId   = $element->getId();
$containerId = $elementId . '_rows';
$hiddenId    = $elementId . '_json';
?>
<div id="<?= $escaper->escapeHtmlAttr($containerId) ?>" class="repeater-container"></div>

<button type="button"
    class="action-default scalable repeater-add"
    onclick="addRow_<?= $escaper->escapeHtmlAttr($elementId) ?>()">
    &#43; Add <?= $escaper->escapeHtml($block->getLabel()) ?>
</button>

<input type="hidden"
    id="<?= $escaper->escapeHtmlAttr($hiddenId) ?>"
    name="<?= $escaper->escapeHtmlAttr($element->getName()) ?>"
    class="widget-option"
    value="<?= $escaper->escapeHtmlAttr($block->getExistingRowsJson()) ?>" />

<script>
    (new RepeaterWidget({
        containerId:  '<?= $escaper->escapeJs($containerId) ?>',
        elementId:    '<?= $escaper->escapeJs($elementId) ?>',
        hiddenId:     '<?= $escaper->escapeJs($hiddenId) ?>',
        label:        '<?= $escaper->escapeJs($block->getLabel()) ?>',
        fields:       <?= /* @noEscape */ $block->getFieldTemplatesJson() ?>,
        existingRows: <?= /* @noEscape */ $block->getExistingRowsJson() ?>,
    })).init();
</script>
